#!/usr/bin/env true
#
# description:
#   EDA and PCB manufacturing softwares
#   3D modeling and 3D printing softwares
#
# require:
#   - pacman (Arch Linux Package Manager)
#   - yay (AUR Wrapper)
#       git clone https://aur.archlinux.org/yay-bin.git /tmp/yay; cd /tmp/yay; makepkg -si
#   - base-devel (meta package)
#       see https://www.archlinux.org/groups/x86_64/base-devel/

## Electronics

kicad                       # http://kicad.org/
kicad-library               # http://kicad.org/
kicad-library-3d            # http://kicad.org/
python-kikit                # https://github.com/yaqwsx/KiKit
aur/pcbdraw                 # https://github.com/yaqwsx/PcbDraw
esptool                     # https://github.com/espressif/esptool
espflash                    # https://github.com/esp-rs/espflash

