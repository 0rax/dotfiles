{
  "cli_default_open_behavior": "new_window",
  "git_panel": {
    "dock": "left",
  },
  "document_symbols": "off",
  "document_folding_ranges": "off",
  "semantic_tokens": "off",
  "languages": {
    "TOML": {
      "tab_size": 2,
    },
    "Markdown": {
      "formatter": "language_server",
      "soft_wrap": "none",
    },
  },
  "agent": {
    "sidebar_side": "right",
    "dock": "right",
    "default_model": {
      "provider": "opencode",
      "model": "kimi-k2.5",
    },
    "model_parameters": [],
  },
  "edit_predictions": {
    "mode": "subtle",
    "provider": "zed",
  },
  "agent_servers": {
    "gemini": {
      "type": "registry"
    },
    "claude-acp": {
      "type": "registry",
    },
    "opencode": {
      "type": "registry",
    },
    "github-copilot": {
      "type": "registry",
    },
  },
  "preferred_line_length": 92,
  "relative_line_numbers": "wrapped",
  "soft_wrap": "bounded",
  "diagnostics": {
    "inline": {
      "min_column": 80,
      "enabled": true,
      "padding": 4,
    },
  },
  "git": {
    "git_gutter": "tracked_files",
    "inline_blame": {
      "enabled": true,
      "min_column": 80,
      "delay_ms": 500,
      "show_commit_summary": true,
      "padding": 4,
    },
  },
  "scrollbar": {
    "show": "always",
    "diagnostics": "all",
    "cursors": true,
    "git_diff": true,
    "search_results": true,
    "selected_symbol": true,
  },
  "toolbar": {
    "breadcrumbs": true,
    "quick_actions": true,
    "selections_menu": true,
    "agent_review": true,
    "code_actions": true,
  },
  "ui_font_family": "Inter Variable",
  "buffer_font_family": "Hasklug Nerd Font Mono",
  "buffer_font_fallbacks": ["Hack Nerd Font"],
  "autosave": "on_focus_change",
  "collaboration_panel": {
    "dock": "left",
    "button": false,
  },
  "terminal": {
    "toolbar": {
      "breadcrumbs": false,
    },
    "working_directory": "current_project_directory",
    "dock": "bottom",
  },
  "outline_panel": {
    "dock": "right",
  },
  "zoomed_padding": true,
  "active_pane_modifiers": {
    "border_size": 0.0,
    "inactive_opacity": 0.9,
  },
  "centered_layout": {
    "left_padding": 0.2,
    "right_padding": 0.2,
  },
  "tab_bar": {
    "show_tab_bar_buttons": true,
    "show_nav_history_buttons": true,
  },
  "tabs": {
    "show_diagnostics": "errors",
    "show_close_button": "hover",
    "file_icons": true,
    "git_status": true,
  },
  "title_bar": {
    "show_branch_status_icon": true,
    "show_user_picture": false,
  },
  "status_bar": {
    "active_language_button": true,
  },
  "project_panel": {
    "dock": "left",
    "button": true,
    "indent_size": 16,
    "auto_fold_dirs": true,
    "entry_spacing": "standard",
    "hide_root": false,
    "sticky_scroll": true,
    "indent_guides": {
      "show": "always",
    },
    "scrollbar": {
      "show": "auto",
    },
    "show_diagnostics": "all",
    "sort_mode": "directories_first",
  },
  "gutter": {
    "min_line_number_digits": 3,
    "line_numbers": true,
    "runnables": true,
    "folds": true,
    "breakpoints": true,
  },
  "bottom_dock_layout": "contained",
  "indent_guides": {
    "enabled": true,
    "line_width": 0,
    "active_line_width": 1,
    "coloring": "indent_aware",
    "background_coloring": "indent_aware",
  },
  "inlay_hints": {
    "enabled": false,
    "show_type_hints": true,
    "show_parameter_hints": true,
    "show_other_hints": true,
    "show_background": true,
    "toggle_on_modifiers_press": {
      "control": true,
      "shift": true,
    },
  },
  "icon_theme": "Material Icon Theme",
  "base_keymap": "VSCode",
  "telemetry": {
    "metrics": false,
    "diagnostics": false,
  },
  "vim_mode": true,
  "ui_font_size": 16,
  "buffer_font_size": 16,
  "theme": "Nightfox - opaque",
  "wrap_guides": [80],
  "scroll_beyond_last_line": "off",
  "vertical_scroll_margin": 0,
  "show_signature_help_after_edits": true,
  "auto_signature_help": true,
  "cursor_blink": false,
  "command_aliases": {
    "W": "w",
    "Wq": "wq",
    "Q": "q",
  },
  "remove_trailing_whitespace_on_save": true,
  "resize_all_panels_in_dock": ["left", "right", "bottom"],
  "show_whitespaces": "boundary",
  "whitespace_map": {
    "space": "•",
    "tab": "→",
  },
  "line_indicator_format": "short",
  "file_finder": {
    "file_icons": true,
    "include_ignored": "smart",
    "modal_max_width": "small",
    "skip_focus_for_active_in_search": false,
  },
  "lsp": {
    "gopls": {
      "initialization_options": {
        "gofumpt": true,
      },
    },
    "yaml-language-server": {
      "settings": {
        "yaml": {
          "completion": true,
          "validate": true,
          "hover": true,
          "schemaStore": {
            "enable": true,
          },
          "kubernetesCRDStore": {
            "enable": true,
          },
          "schemas": {
            "https://raw.githubusercontent.com/compose-spec/compose-spec/refs/heads/main/schema/compose-spec.json": [
              "compose.yml",
              "compose.yaml",
              "compose.*.yml",
              "compose.*.yaml",
              "docker-compose.yml",
              "docker-compose.yaml",
              "docker-compose.*.yml",
              "docker-compose.*.yaml",
            ],
          },
        },
      },
    },
  },
}
